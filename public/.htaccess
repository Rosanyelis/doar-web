<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # SPA fallback: sirve index.html para rutas del cliente (React Router).
  # En nginx equivalente: try_files $uri $uri/ /index.html;
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
